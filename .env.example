# Optional — used only for experimental or shadow features
OPENAI_API_KEY=

# Frontend: leave empty for local dev (uses Vite proxy), set to deployed API URL in production.
VITE_API_BASE_URL=

# Backend CORS: comma-separated list of allowed frontend origins.
# Example: ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Optional behavior flags for phase 5.7 testing
# USE_LLM_SHADOW_MODE=1
# LLM_SHADOW_TEST_OUTPUT={"proposal":"Example neutral rewrite"}
